{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://montrealai.github.io/goalos-agijobmanager-ascension/schemas/loop-to-rsi.schema.json",
  "title": "GoalOS Loop to RSI Demo Contract",
  "type": "object",
  "required": [
    "release",
    "title",
    "route",
    "posture",
    "pipeline",
    "loopToRsiMap",
    "hardGates",
    "move37",
    "claimBoundary"
  ],
  "properties": {
    "release": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "route": {
      "type": "string"
    },
    "productionUrl": {
      "type": "string"
    },
    "posture": {
      "type": "object"
    },
    "thesis": {
      "type": "string"
    },
    "pipeline": {
      "type": "array",
      "minItems": 8,
      "items": {
        "type": "string"
      }
    },
    "loopToRsiMap": {
      "type": "array",
      "minItems": 9,
      "items": {
        "type": "object",
        "required": [
          "loopRule",
          "rsiControl"
        ]
      }
    },
    "hardGates": {
      "type": "array",
      "minItems": 6,
      "items": {
        "type": "string"
      }
    },
    "move37": {
      "type": "object",
      "required": [
        "trigger",
        "requiredSteps",
        "principle"
      ]
    },
    "claimBoundary": {
      "type": "string"
    }
  }
}