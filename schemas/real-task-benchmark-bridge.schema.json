    "title": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "route": {
      "type": "string"
    },
    "teachingLine": {
      "type": "string"
    },
    "publicSafety": {
      "type": "object"
    },
    "taskFamilies": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "baselineLadder": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "promotionGates": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "outcomes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "claimBoundary": {
      "type": "string"
    }
  }
}