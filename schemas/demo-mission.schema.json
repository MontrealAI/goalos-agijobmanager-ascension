{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GoalOS AGIJobManager User Demo Mission",
  "type": "object",
  "required": [
    "id",
    "title",
    "objective",
    "gates",
    "docketClass",
    "expectedArtifact"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "objective": {
      "type": "string"
    },
    "gates": {
      "type": "array",
      "minItems": 10,
      "items": {
        "type": "string"
      }
    },
    "docketClass": {
      "type": "string"
    },
    "expectedArtifact": {
      "type": "string"
    },
    "risk": {
      "type": "string"
    },
    "audience": {
      "type": "string"
    }
  }
}
