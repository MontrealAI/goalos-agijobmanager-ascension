{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GoalOS Sovereign Machine Economy Capability Contract",
  "type": "object",
  "required": [
    "schemaVersion",
    "name",
    "productionUrl",
    "repository",
    "canonicalIdentities",
    "sourceLineage",
    "operatingLoop",
    "capabilities",
    "publicSafetyBoundary"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "productionUrl": {
      "type": "string",
      "const": "https://montrealai.github.io/goalos-agijobmanager-ascension/"
    },
    "repository": {
      "type": "string",
      "const": "MontrealAI/goalos-agijobmanager-ascension"
    },
    "canonicalIdentities": {
      "type": "object",
      "required": [
        "AGIJobManager",
        "AGIALPHA",
        "chainId"
      ],
      "properties": {
        "AGIJobManager": {
          "type": "string",
          "const": "0xB3AAeb69b630f0299791679c063d68d6687481d1"
        },
        "AGIALPHA": {
          "type": "string",
          "const": "0xA61a3B3a130a9c20768EEBF97E21515A6046a1fA"
        },
        "chainId": {
          "type": "integer",
          "const": 1
        }
      }
    },
    "sourceLineage": {
      "type": "array",
      "minItems": 4
    },
    "operatingLoop": {
      "type": "array",
      "minItems": 10
    },
    "capabilities": {
      "type": "array",
      "minItems": 7
    },
    "publicSafetyBoundary": {
      "type": "object"
    },
    "claimBoundary": {
      "type": "array"
    }
  }
}