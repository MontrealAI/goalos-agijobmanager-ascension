{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ProofConditionedRouterObservatoryDemo",
  "type": "object",
  "required": [
    "demo",
    "version",
    "routerFamily",
    "hardGates",
    "safetyBoundary"
  ],
  "properties": {
    "demo": {
      "const": "proof-conditioned-router-observatory"
    },
    "version": {
      "const": "v30"
    },
    "publicSafe": {
      "const": true
    },
    "law": {
      "type": "string"
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "routerFamily": {
      "type": "array",
      "minItems": 6,
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "use"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "use": {
            "type": "string"
          }
        }
      }
    },
    "receiptObject": {
      "const": "GoalOSProofConditionedRoutingReceipt"
    },
    "hardGates": {
      "type": "array",
      "minItems": 8,
      "items": {
        "type": "string"
      }
    },
    "safetyBoundary": {
      "type": "object"
    }
  }
}