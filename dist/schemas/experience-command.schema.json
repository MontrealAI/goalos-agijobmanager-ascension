{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GoalOS Experience Command Receipt",
  "type": "object",
  "required": [
    "receiptType",
    "version",
    "route",
    "publicSafe",
    "journeys",
    "outputArtifact"
  ],
  "properties": {
    "receiptType": {
      "const": "GoalOSExperienceCommandReceipt"
    },
    "version": {
      "type": "string"
    },
    "route": {
      "type": "string"
    },
    "purpose": {
      "type": "string"
    },
    "publicSafe": {
      "type": "object"
    },
    "journeys": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "outputArtifact": {
      "const": "ExperienceCommandReceipt"
    }
  }
}